# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_BASE_URL=https://api.telegram.org
TELEGRAM_PROXY=
TELEGRAM_FORCE_CURL=0
TELEGRAM_POLL_INTERVAL_SEC=0.5
TELEGRAM_LONG_POLL_TIMEOUT_SEC=20
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_MESSAGE_MAX_CHARS=3500

# Allowed roots (comma-separated)
ALLOWED_ROOTS=/path/to/projects
DEFAULT_WORKDIR=/path/to/projects
PROJECT_ROOT=/path/to/projects
PROJECT_MEMORY_DIR=data/memory
PROJECT_MEMORY_MAX_LINES=600
PROJECT_MEMORY_CONTEXT_LINES=80
PROJECT_CONTEXT_FILES=AGENTS.md,agents.md,README.md,readme.md,TASK.md,task.md,PRD.md,prd.md,DESIGN.md,design.md,STATUS.md,status.md,service/README.md,service/readme.md,server/README.md,server/readme.md,docs/README.md,docs/readme.md,docs/OVERVIEW.md,docs/overview.md,docs/DEPLOYMENT.md,docs/DEPLOYMENT_MAC_MINI.md,DEPLOYMENT.md
PROJECT_CONTEXT_MAX_CHARS=6000
FLUTTER_SDK_PATH=
FLUTTER_AUTO_ADD_DIR=1

# Codex CLI integration
CODEX_TASK_COMMAND=codex
CODEX_TASK_ARGS=
CODEX_TIMEOUT_SEC=600
CODEX_MAX_WORKERS=1
TASK_STALE_SEC=0
AUTO_VERIFY=1
AUTO_VERIFY_TIMEOUT_SEC=300
AUTO_PLAN=1
AUTO_RETRY_ON_FAILURE=1
AUTO_RETRY_ATTEMPTS=1

# Provider selection
# PROVIDER_DEFAULT=codex
# PROVIDER_COMMANDS=codex=codex,kimi=kimi
# PROVIDER_ARGS=codex=,kimi=

# Provider keys (used by the CLI you run; set only what your CLI requires)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# MOONSHOT_API_KEY=
# Optional base URLs (if your CLI supports them)
# OPENAI_BASE_URL=
# ANTHROPIC_BASE_URL=
# MOONSHOT_BASE_URL=

# Approval policy
REQUIRE_APPROVAL_FOR_DELETE=1
DELETE_KEYWORDS=delete,remove,rm,trash,cleanup,drop,reset,wipe

# Storage
TASK_STORE_PATH=data/tasks.json

# Power management
ENABLE_CAFFEINATE=0
